# ============================================
# ColoriMagiques - Configuration Environnement
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# --- Serveur ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# --- Base de données MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=colorimagiques
DB_PASSWORD=colorimagiques_secret
DB_NAME=colorimagiques

# --- JWT ---
JWT_SECRET=change_me_in_production_super_secret_key_32chars
JWT_EXPIRES_IN=7d

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_CURRENCY=eur

# --- Email SMTP (Gmail example) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
EMAIL_FROM=ColoriMagiques <noreply@colorimagiques.com>

# --- Fichiers ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
SIGNED_URL_SECRET=change_me_another_secret_key_32chars
SIGNED_URL_EXPIRY=86400

# --- Admin par défaut ---
ADMIN_EMAIL=admin@colorimagiques.com
ADMIN_PASSWORD=Admin123!
